# MongoDB (required in production; must not be localhost/127.0.0.1 in production)
# MONGO_URI is accepted as an alias for backward compatibility.
MONGODB_URI=mongodb://127.0.0.1:27017/prime_oils

PORT=5000

# JWT signing secret — required, min 32 characters, not "default_secret" or "secret"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Optional token lifetimes
JWT_EXPIRE=24h
REFRESH_TOKEN_EXPIRE=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Path to ProductImages.zip (optional; seed script has a default)
PRODUCT_IMAGES_ZIP=

# Comma-separated allowed browser origins (production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Firebase Admin (JSON string or use GOOGLE_APPLICATION_CREDENTIALS)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Web API key — enables password-reset emails from the API (Identity Toolkit)
FIREBASE_WEB_API_KEY=

# Reserved super admin email (cannot be disabled or re-invited)
SUPER_ADMIN_EMAIL=admin@primeoil.com
